# Production environment — copy to .env on your server before `docker compose up`
# Generate secrets: openssl rand -base64 48

# Required
JWT_SECRET=replace-with-long-random-string
JWT_REFRESH_SECRET=replace-with-another-long-random-string
POSTGRES_PASSWORD=replace-with-strong-db-password

# Your public site URL (no trailing slash)
CORS_ORIGIN=https://yourdomain.com

# Optional — Google OAuth (update callback in Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.yourdomain.com/api/v1/auth/google/callback

# Billing (keep false until payments are wired)
BILLING_ENABLED=false
FREE_TRIAL_DAYS=30
