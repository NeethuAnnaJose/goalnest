# RAZORPAY_KEY_SECRET=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

AWS_S3_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

OPENAI_API_KEY=
