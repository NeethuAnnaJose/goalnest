# Proxied to Nest backend at http://localhost:3001 (see next.config.mjs rewrites)
NEXT_PUBLIC_API_URL=/api/v1

# Billing — false = free launch period, hide paid pricing (must match backend BILLING_ENABLED)
NEXT_PUBLIC_BILLING_ENABLED=false
NEXT_PUBLIC_FREE_TRIAL_DAYS=30

# Optional: override backend target for the dev proxy
# API_PROXY_TARGET=http://localhost:3001
